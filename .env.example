# Local and deployment configuration. Keep real values only in .env or your host dashboard.
# Do not commit secrets, direct connection strings, or service-role keys.

# Supabase server-side access (required for the durable cold path and evidence stores).
SUPABASE_URL=
SUPABASE_SECRET_KEY=
# Optional direct Postgres access for `python -m metricthread.cli migrate` when TCP is reachable.
DATABASE_URL=

# Upstash Redis Stream (required by the simulator and live hot path).
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# Development fallback. This must remain Gemini until a funded OpenAI inference check succeeds.
AI_PROVIDER=gemini
GEMINI_API_KEY=
GEMINI_MODEL=gemini-3.1-flash-lite

# Required before a Build Week submission or video claims live GPT-5.6 output.
OPENAI_API_KEY=
OPENAI_REASONING_MODEL=gpt-5.6

# Deployment safety. Set the exact Vercel URL after the frontend is deployed.
CORS_ALLOWED_ORIGINS=http://localhost:5173,http://127.0.0.1:5173
# true makes the deployed judge experience non-destructive while preserving simulation and forecasts.
DEMO_READ_ONLY=false
